# cricket secrets. Copy to .env (gitignored) and fill in. Never commit .env.

# --- MUSH connection (the bot's own account) ---
CRICKET_MUSH_HOST=mush.example.org
CRICKET_MUSH_PORT=4201
CRICKET_MUSH_USE_TLS=false
CRICKET_MUSH_NAME=CricketBOT
CRICKET_MUSH_PASSWORD=changeme

# Local control socket port for cricket-ctl (loopback only).
CRICKET_MUSH_CONTROL_PORT=4250

# Local HTTP control panel port (loopback only).
CRICKET_HTTP_PORT=4280

# --- Test-server credentials (used only by tools/mush_admin.py and tools/mush_probe.py) ---
# Throwaway accounts on the local test PennMUSH. They live here, never in the committed
# tools/ scripts. Placeholders below -- set real values in your .env.
CRICKET_TEST_GOD_PW=changeme        # God ("One"); secures the otherwise-passwordless God
CRICKET_TEST_CRICKET_PW=changeme    # the bot account on the test world
CRICKET_TEST_BAZIL_PW=changeme      # admin/wizard test player
CRICKET_TEST_BOB_PW=changeme        # regular test player

/reference/
/logs/
.env
config.local.*
__pycache__/
*.pyc
.venv/
.pytest_cache/
config.toml

# Memory DB holds conversation content -- never commit it. The config DB
# (data/cricket-config.sqlite3) IS committed; only the memory DB is ignored.
/data/cricket-memory.sqlite3
/data/cricket-memory.sqlite3-wal
/data/cricket-memory.sqlite3-shm
# Turn-trace debug logs are per-run analysis artifacts, not code -- keep them local.
/data/traces/
/data/traces-*/
/evals/reports/*.json

# Fine-tune LoRA adapters + checkpoints are multi-GB binaries -- keep local, not in git.
/data/finetune/*-lora/
# MUSH DB dumps contain player PII (emails in finger.*) and are re-fetchable over SSH.
/knowledge/sources/mush-dump/
# Line-numbered render inputs are regenerable via `rplog_to_jsonl.py --render`.
/data/dataset_full/_render/
# Assembled turn-level JSONL is regenerable from _labeled maps + pages via rplog_assemble.
/data/dataset_full/_assembled/
# Scratch registry from the live-scene driver.
/data/_scene_reg.json
